@model KertKerdes.Models.Kerdes

@{
    ViewData["Title"] = "Kérdés részletei";
}

<div class="container mt-4 question-layout">

    <div class="mb-4">
        <a href="/Kerdes" class="text-decoration-none text-muted">
            <i class="bi bi-arrow-left"></i> Vissza a kérdésekhez
        </a>
    </div>

    <div class="question-card-modern d-flex gap-4">

        <div class="vote-box-modern">
            <a href="/Szavazat/KerdesFel/@Model.Id">
                <i class="bi bi-chevron-up"></i>
            </a>

            <div class="vote-number">
                @Model.Szavazat
            </div>

            <a href="/Szavazat/KerdesLe/@Model.Id">
                <i class="bi bi-chevron-down"></i>
            </a>
        </div>

        <div class="question-body">

            <h2>@Model.Cim</h2>

            <div class="mb-3 d-flex flex-wrap gap-2">

                @if (Model.Temakor != null)
                {
                    <span class="tag-pill">@Model.Temakor.Nev</span>
                }

                @foreach (var cimke in Model.KerdesCimkek)
                {
                    if (cimke.Cimke != null)
                    {
                        <span class="tag-pill">#@cimke.Cimke.Nev</span>
                    }
                }

            </div>

            <div class="question-description">
                @Model.Leiras
            </div>

            <div class="question-footer">
                <small>
                    <i class="bi bi-person"></i> @Model.Felhasznalo?.Felhasznalonev
                    &nbsp; · &nbsp;
                    <i class="bi bi-clock"></i> @Model.Datum.ToString("yyyy.MM.dd HH:mm")
                </small>
            </div>

        </div>

    </div>

    <div class="mt-5">
        <h4 class="answer-section-title">
            <i class="bi bi-chat-left-text"></i> @Model.Valaszok.Count válasz
        </h4>

        @if (Model.Valaszok.Any())
        {
            foreach (var valasz in Model.Valaszok.OrderByDescending(v => v.Elfogadott))
            {
                var valaszClass = valasz.Elfogadott
                ? "answer-card answer-accepted d-flex gap-4"
                : "answer-card d-flex gap-4";

                <div class="@valaszClass">

                    <div class="vote-box-modern">
                        <a href="/Szavazat/ValaszFel/@valasz.Id">
                            <i class="bi bi-chevron-up"></i>
                        </a>

                        <div class="vote-number">
                            @valasz.Szavazat
                        </div>

                        <a href="/Szavazat/ValaszLe/@valasz.Id">
                            <i class="bi bi-chevron-down"></i>
                        </a>
                    </div>

                    <div class="question-body">

                        <div class="question-description">
                            @valasz.Szoveg
                        </div>

                        <div class="answer-meta">
                            <small>
                                <i class="bi bi-person"></i> @valasz.Felhasznalo?.Felhasznalonev
                                &nbsp; · &nbsp;
                                <i class="bi bi-clock"></i> @valasz.Datum.ToString("yyyy.MM.dd HH:mm")
                            </small>
                        </div>

                        @if (!valasz.Elfogadott &&
                                        Context.Session.GetInt32("FelhasznaloId") == Model.FelhasznaloId &&
                                        valasz.FelhasznaloId != Model.FelhasznaloId)
                        {
                            <div class="mt-3">
                                <form method="post" action="/Valasz/Elfogad/@valasz.Id" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-success btn-sm rounded-pill">
                                        <i class="bi bi-check-circle"></i> Elfogadás
                                    </button>
                                </form>
                            </div>
                        }

                        @if (valasz.Elfogadott)
                        {
                            <div class="mt-2">
                                <span class="accepted-badge">
                                    <i class="bi bi-check-circle"></i> Elfogadott válasz
                                </span>
                            </div>
                        }

                        @if (valasz.Elfogadott &&
                                        Context.Session.GetInt32("FelhasznaloId") == Model.FelhasznaloId)
                        {
                            <div class="mt-3">
                                <form method="post" action="/Valasz/ElfogadasVisszavon/@valasz.Id" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-secondary btn-sm rounded-pill">
                                        <i class="bi bi-arrow-counterclockwise"></i> Elfogadás visszavonása
                                    </button>
                                </form>
                            </div>
                        }

                    </div>

                </div>
            }
        }
        else
        {
            <div class="question-empty-state">
                <i class="bi bi-chat fs-1"></i>
                <div class="mt-3">Még nincs válasz. Légy te az első!</div>
            </div>
        }

    </div>

    <div class="mt-4 answer-form-card">

        <h5>Válaszolj a kérdésre</h5>

        <form method="post" action="/Valasz/Letrehozas">

            @if (TempData["ValaszHiba"] != null)
            {
                <div class="alert alert-danger mb-3">
                    @TempData["ValaszHiba"]
                </div>
            }

            <input type="hidden" name="KerdesId" value="@Model.Id" />

            <textarea name="Szoveg"
                      class="form-control mb-3"
                      rows="5"
                      placeholder="Írd le a válaszod részletesen...">@TempData["ValaszSzoveg"]</textarea>

            <button type="submit" class="btn-modern-green">
                <i class="bi bi-send"></i> Válasz beküldése
            </button>

        </form>

    </div>

    @if (TempData["ValaszBekuldve"] != null)
    {
        <div id="valaszModal" class="modal fade show" style="display:block; background:rgba(0,0,0,0.45);" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 rounded-4 shadow">
                    <div class="modal-body text-center p-4">
                        <div class="mb-3 fs-1 text-success">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                        <h4>Válasz sikeresen beküldve</h4>
                        <p class="text-muted mt-3">
                            A válasz jóváhagyás után válik láthatóvá.
                        </p>
                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <button type="button"
                                    class="btn btn-success rounded-pill px-4"
                                    onclick="document.getElementById('valaszModal').style.display='none';">
                                Rendben
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (TempData["ValaszElfogadva"] != null)
    {
        <div id="elfogadasModal" class="modal fade show" style="display:block; background:rgba(0,0,0,0.45);" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 rounded-4 shadow">
                    <div class="modal-body text-center p-4">
                        <div class="mb-3 fs-1 text-success">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                        <h4>Válasz elfogadva</h4>
                        <p class="text-muted mt-3">
                            Ez a válasz most már kiemelten jelenik meg a kérdés alatt.
                        </p>
                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <button type="button"
                                    class="btn btn-success rounded-pill px-4"
                                    onclick="document.getElementById('elfogadasModal').style.display='none';">
                                Rendben
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (TempData["ValaszElfogadasTorolve"] != null)
    {
        <div id="torlesModal" class="modal fade show" style="display:block; background:rgba(0,0,0,0.45);" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 rounded-4 shadow">
                    <div class="modal-body text-center p-4">
                        <div class="mb-3 fs-1 text-secondary">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </div>
                        <h4>Elfogadás visszavonva</h4>
                        <p class="text-muted mt-3">
                            A válasz már nem kiemelt elfogadott válasz.
                        </p>
                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <button type="button"
                                    class="btn btn-secondary rounded-pill px-4"
                                    onclick="document.getElementById('torlesModal').style.display='none';">
                                Rendben
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

</div>