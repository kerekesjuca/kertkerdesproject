@model List<KertKerdes.Models.Kerdes>

@{
    ViewData["Title"] = "Kérdések";
}



<div class="hero-section">

    <h1>Kertészeti Közösség</h1>

    <p>Kérdezz, válaszolj, és oszd meg tudásod a kertészet szerelmeseivel!</p>

    <div class="row g-3 mt-3">

        <div class="col-md-6">
            <form method="get" action="/Kerdes/Index" class="search-box">
                <input type="text"
                       name="kereses"
                       placeholder="Keresés kérdésekben..." />
            </form>
        </div>

        <div class="col-md-3">
            <a href="/Kerdes/Letrehozas" class="btn-modern-green d-inline-block">
                <i class="bi bi-plus-lg"></i> Kérdés feltevése
            </a>
        </div>

    </div>

</div>

<div class="container">

    <div class="main-grid">

        <div>

            <div class="mb-4">
                <h4><i class="bi bi-funnel"></i> Szűrés témakör szerint</h4>
            </div>

            <div class="temakor-sor">

                <a href="/Kerdes"
                   class="temakor-badge @(ViewBag.AktivTemakor == null ? "active" : "")">
                    Összes
                </a>

                @foreach (var temakor in ViewBag.Temakorok)
                {
                    <a href="/Kerdes?temakorId=@temakor.Id"
                       class="temakor-badge @(ViewBag.AktivTemakor == temakor.Id ? "active" : "")">
                        @temakor.Nev
                    </a>
                }

            </div>

            @foreach (var kerdes in Model)
            {
                <div class="question-card-modern d-flex gap-3">

                    <div class="vote-box-modern">

                        <a href="/Szavazat/KerdesFel/@kerdes.Id">
                            <i class="bi bi-chevron-up"></i>
                        </a>

                        <div class="vote-number">
                            @kerdes.Szavazat
                        </div>

                        <a href="/Szavazat/KerdesLe/@kerdes.Id">
                            <i class="bi bi-chevron-down"></i>
                        </a>

                    </div>

                    <div class="question-body">

                        <h4>
                            <a href="/Kerdes/Reszletek/@kerdes.Id">
                                @kerdes.Cim
                            </a>
                        </h4>

                        <div class="question-description">
                            @kerdes.Leiras
                        </div>

                        <div class="mt-3">

                            @foreach (var cimke in kerdes.KerdesCimkek)
                            {
                                if (cimke.Cimke != null)
                                {
                                    <a href="/Kerdes?cimke=@cimke.Cimke.Nev"
                                       class="tag-pill">
                                        #@cimke.Cimke.Nev
                                    </a>
                                }
                            }

                        </div>

                        <div class="question-footer">

                            <small>
                                <i class="bi bi-chat-left-text"></i> @kerdes.Valaszok.Count(v => v.Jovahagyva) válasz
                            </small>

                            @if (kerdes.Valaszok.Any(v => v.Elfogadott && v.Jovahagyva))
                            {
                                <small class="ms-3 accepted-answer-indicator">
                                    <i class="bi bi-check-circle-fill"></i> Elfogadott válasz
                                </small>
                            }

                            @if (kerdes.Felhasznalo != null)
                            {
                                <small class="ms-3">
                                    <i class="bi bi-person"></i> @kerdes.Felhasznalo.Felhasznalonev
                                </small>

                                <small class="ms-3">
                                    <i class="bi bi-clock"></i> @kerdes.Datum.ToShortDateString()
                                </small>
                            }

                        </div>

                    </div>

                </div>
            }

        </div>

        <div>

            <div class="side-card">
                <h4><i class="bi bi-graph-up-arrow"></i> Népszerű címkék</h4>

                <div class="tag-list mt-3">

                    @foreach (var cimke in ViewBag.TopCimkek)
                    {
                        <a href="/Kerdes?cimke=@cimke.Nev" class="tag-link">
                            <span class="tag-pill-inline">#@cimke.Nev (@cimke.Db)</span>
                        </a>
                    }

                </div>

            </div>

            <div class="side-card green-card">
                <h4>Közösségi statisztika</h4>

                <div class="stat-big">
                    @ViewBag.KerdesDb kérdés
                </div>

                <div class="stat-big">
                    @ViewBag.ValaszDb válasz
                </div>
            </div>

        </div>

    </div>

</div>

@if (TempData["KerdesSikeres"] != null)
{
    <div id="kerdesModal"
         class="modal fade show"
         style="display:block; background:rgba(0,0,0,0.45);"
         tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content border-0 rounded-4 shadow">

                <div class="modal-body text-center p-4">

                    <div class="mb-3 fs-1 text-success">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>

                    <h4>Kérdés sikeresen beküldve</h4>

                    <p class="text-muted mt-3">
                        A kérdés jóváhagyás után válik láthatóvá.
                    </p>

                    <div class="d-flex justify-content-center gap-3 mt-4">

                        <button type="button"
                                class="btn btn-success rounded-pill px-4"
                                onclick="document.getElementById('kerdesModal').style.display='none';">
                            Rendben
                        </button>

                        <a href="/Kerdes"
                           class="btn btn-outline-secondary rounded-pill px-4">
                            Vissza a főoldalra
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>
}